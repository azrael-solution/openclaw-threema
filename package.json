{
  "name": "openclaw-threema",
  "version": "0.6.7",
  "description": "Threema Gateway channel plugin for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "rm -rf dist && tsc -p tsconfig.json"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "threema",
      "label": "Threema",
      "selectionLabel": "Threema Gateway (E2E)",
      "docsPath": "/channels/threema",
      "blurb": "Privacy-focused Swiss messenger via Threema Gateway API.",
      "order": 45,
      "aliases": [
        "threema-gateway"
      ]
    },
    "id": "threema",
    "compat": {
      "pluginApi": ">=1.0.0"
    },
    "build": {
      "openclawVersion": "2026.5.3"
    }
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "dist/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "threema",
    "messaging",
    "e2e",
    "privacy",
    "channel-plugin"
  ],
  "author": "aza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azrael-solution/openclaw-threema"
  }
}
